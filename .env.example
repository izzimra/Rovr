# Rovr environment variables
# =============================================================================
# Client-visible (safe to ship in the browser bundle)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=

# =============================================================================
# Server-only (never expose to the browser)
# =============================================================================
MAPBOX_SECRET_TOKEN=
GEMINI_API_KEY=

# =============================================================================
# AWS infrastructure (future-facing).
# Not required while developing locally. In production these are resolved from
# AWS Secrets Manager / IAM role credentials, not from plaintext env vars.
# =============================================================================
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
